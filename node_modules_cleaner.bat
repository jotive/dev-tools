@echo off
echo Buscando node_modules en C:\Users\%USERNAME%\...
echo Puede tardar unos minutos.
echo.

set TOTAL=0
for /f "delims=" %%d in ('powershell -Command "Get-ChildItem 'C:\Users\%USERNAME%' -Recurse -ErrorAction SilentlyContinue -Filter node_modules -Directory | Where-Object { $_.FullName -notmatch 'node_modules\\\\node_modules' } | ForEach-Object { $s=(Get-ChildItem $_.FullName -Recurse -ErrorAction SilentlyContinue | Measure-Object Length -Sum).Sum; Write-Host ('{0,6} MB  {1}' -f [math]::Round($s/1MB,0), $_.FullName) } | Sort-Object"') do (
    echo %%d
)

echo.
set /p CONFIRM="Borrar TODOS los node_modules listados? (s/N): "
if /i "%CONFIRM%"=="s" (
    echo Borrando...
    powershell -Command "Get-ChildItem 'C:\Users\%USERNAME%' -Recurse -ErrorAction SilentlyContinue -Filter node_modules -Directory | Where-Object { $_.FullName -notmatch 'node_modules\\node_modules' } | Remove-Item -Recurse -Force -ErrorAction SilentlyContinue"
    echo Listo. Reinstala con npm install en cada proyecto que necesites.
) else (
    echo Cancelado.
)
